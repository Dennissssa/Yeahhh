--- !u!114 &30813214
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 30813210}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4b284b0819a2fc64c83eee2ee8ce456c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::JiU.DialogueController
  dialogueRoot: {fileID: 429690925}
  dialogueText: {fileID: 1059647158}
  lines:
  - text: I found out your system got hacked. That's on me.
    lineAudio: {fileID: 8300000, guid: c6ccb66654deff94ba05c084d88d215e, type: 3}
    advanceDelaySeconds: 4
    spriteSwapsWhenLineEnds: []
  - text: I don't want to get fired. And I'm guessing you don't want to lose your
      job on day one either.
    lineAudio: {fileID: 8300000, guid: c6ccb66654deff94ba05c084d88d215e, type: 3}
    advanceDelaySeconds: 5
    spriteSwapsWhenLineEnds: []
  - text: Give me some time. I'll handle the hack.
    lineAudio: {fileID: 8300000, guid: c6ccb66654deff94ba05c084d88d215e, type: 3}
    advanceDelaySeconds: 3
    spriteSwapsWhenLineEnds: []
  - text: "But you can't let the boss catch you in the meantime \u2014 or we're both
      done for."
    lineAudio: {fileID: 8300000, guid: c6ccb66654deff94ba05c084d88d215e, type: 3}
    advanceDelaySeconds: 5
    spriteSwapsWhenLineEnds: []
  - text: '"If any of the smart devices in the office start acting up, just patch
      it the dumb way for now.'
    lineAudio: {fileID: 8300000, guid: c6ccb66654deff94ba05c084d88d215e, type: 3}
    advanceDelaySeconds: 6
    spriteSwapsWhenLineEnds: []
  - text: "You heard me right. Find something to hit it with \u2014 good old percussive
      maintenance."
    lineAudio: {fileID: 8300000, guid: c6ccb66654deff94ba05c084d88d215e, type: 3}
    advanceDelaySeconds: 6
    spriteSwapsWhenLineEnds: []
  - text: Don't panic. I'll keep an eye on your end.
    lineAudio: {fileID: 8300000, guid: c6ccb66654deff94ba05c084d88d215e, type: 3}
    advanceDelaySeconds: 4
    spriteSwapsWhenLineEnds:
    - target: {fileID: 1393917571}
      sprite: {fileID: 0}
  voiceSource: {fileID: 1848746285}
  endAction: 1
  sceneBuildIndexToLoad: 3
  pauseGameWhileDialogue: 1
